.venv/
.envrc

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Large data files
datasets/phototourism
data/sparse_train/
data/sparse_train_lora/
data/sparse_train_lora_v3clean/
data/gf_cache/
data/gf_cache_*/
data/lightglue_training/
data/revisitop1m_stage1/
data/smoke_0046_image_names.txt
*.tar.gz
*.npy
*.h5
*.pt

# Ignore everything under output
output/**
output_1

# Re-include results and its subfolders
!output/results/
!output/results/**/
!output/results/**/*.csv
!output/results/**/*.txt

# Explicit large/generated files still ignored
output/pairs_reichstag.txt
output/pairs_sacre_coeur.txt
output/pairs_st_peters_square.txt

cache*
*.log

# External dependencies
external/

benchmark*
.nfs*

docs
figures

res_*
output/results/**/*.json
