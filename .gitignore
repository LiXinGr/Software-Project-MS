.venv/
.envrc

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Large data files
datasets/phototourism
data/sparse_train/
*.tar.gz
*.npy
*.h5
*.pt

# Ignore everything under output
output/**
output_1

# Re-include results and its subfolders
!output/results/
!output/results/**/
!output/results/**/*.csv
!output/results/**/*.txt

# Explicit large/generated files still ignored
output/pairs_reichstag.txt
output/pairs_sacre_coeur.txt
output/pairs_st_peters_square.txt

cache*
*.log

# External dependencies
external/

benchmark*
.nfs*

docs
figures

res_*
